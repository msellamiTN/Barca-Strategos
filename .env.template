# Phoenix Security Configuration
JWT_SECRET=your_jwt_secret_minimum_32_characters_here
AGENT_SECRET=your_agent_secret_minimum_24_characters_here

# Database Configuration
DB_PASSWORD=your_secure_db_password_here
POSTGRES_DB=barca_db
POSTGRES_USER=barca

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password_here

# AI Configuration
MODEL_PROVIDER=openai
API_KEY=your_openai_api_key_here
MAX_TOKENS=1000
TEMPERATURE=0.7

# Platform Integration Tokens
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
SLACK_BOT_TOKEN=your_slack_bot_token_here
TEAMS_WEBHOOK=your_teams_webhook_url_here
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Web Configuration
WEBHOOK_URL=https://your-domain.com/webhook/telegram
DOMAIN=your-domain.com

# Performance Configuration
AGENT_MEMORY_LIMIT=10MB
MAX_AGENTS=10
SANDBOX_ENABLED=true
SECURE_EXECUTION=true
BOOT_TIMEOUT_SECONDS=1

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# SSL Configuration (optional for production)
SSL_CERT_PATH=./nginx/ssl/cert.pem
SSL_KEY_PATH=./nginx/ssl/key.pem

# Security Configuration
ENABLE_PROMPT_INJECTION_PROTECTION=true
ENABLE_ZERO_TRUST_COMM=true
ENABLE_AUDIT_LOGGING=true

# Monitoring Configuration
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30s
