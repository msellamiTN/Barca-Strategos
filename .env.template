# =============================================================================
# Barca-Strategos Phoenix - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your secure values
# NEVER commit .env to version control!

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Secret for authentication (REQUIRED) - Generate with: openssl rand -base64 32
PHOENIX_JWT_SECRET=your_jwt_secret_minimum_32_characters_here

# Agent secret for inter-agent communication (REQUIRED)
AGENT_SECRET=your_agent_secret_minimum_24_characters_here

# Certificate path for TLS encryption (OPTIONAL)
PHOENIX_CERT_PATH=./nginx/ssl/cert.pem

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database password (REQUIRED)
DB_PASSWORD=your_secure_db_password_here

# Database configuration
POSTGRES_DB=barca_db
POSTGRES_USER=barca
DATABASE_URL=postgresql://barca:your_secure_db_password_here@localhost:5432/barca_db

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

# Redis password (REQUIRED)
REDIS_PASSWORD=your_secure_redis_password_here

REDIS_URL=redis://:your_secure_redis_password_here@localhost:6379

# =============================================================================
# AI CONFIGURATION
# =============================================================================

# AI Model Provider (default: openai)
PHOENIX_MODEL_PROVIDER=openai
MODEL_PROVIDER=openai

# API Key for AI services (REQUIRED)
PHOENIX_API_KEY=your_openai_api_key_here
API_KEY=your_openai_api_key_here

# Maximum tokens for AI responses (default: 1000)
PHOENIX_MAX_TOKENS=1000
MAX_TOKENS=1000

# AI temperature for responses (default: 0.7)
PHOENIX_TEMPERATURE=0.7
TEMPERATURE=0.7

# =============================================================================
# MULTI-PLATFORM INTEGRATION
# =============================================================================

# Telegram Bot Token (OPTIONAL) - Get from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Slack Bot Token (OPTIONAL) - Get from Slack API
SLACK_BOT_TOKEN=your_slack_bot_token_here
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# Microsoft Teams Configuration (OPTIONAL) - Get from Azure Portal
TEAMS_WEBHOOK=your_teams_webhook_url_here
TEAMS_APP_ID=your-teams-app-id-guid
TEAMS_APP_PASSWORD=your-teams-app-password-here

# Discord Bot Token (OPTIONAL) - Get from Discord Developer Portal
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# =============================================================================
# SCALABLE DEPLOYMENT CONFIGURATION
# =============================================================================

# Cluster settings
PHOENIX_CLUSTER_MODE=false
NODE_ID=phoenix-1
PHOENIX_ENABLE_TELEGRAM=true
PHOENIX_ENABLE_DISCORD=true
PHOENIX_ENABLE_SLACK=true
PHOENIX_ENABLE_TEAMS=true

# Load balancer configuration
LOAD_BALANCER_PORT=80
LOAD_BALANCER_SSL_PORT=443

# Auto-scaling settings
AUTOSCALING_ENABLED=true
AUTOSCALING_MIN_REPLICAS=1
AUTOSCALING_MAX_REPLICAS=10
AUTOSCALING_TARGET_CPU=70
AUTOSCALING_TARGET_MEMORY=80

# =============================================================================
# ADVANCED CHAT FEATURES
# =============================================================================

# Telegram Bot Features
TELEGRAM_ENABLE_COMMANDS=/start,/help,/dashboard,/security,/compliance,/risk,/agents,/scale,/status
TELEGRAM_ENABLE_NOTIFICATIONS=true
TELEGRAM_ENABLE_INTERACTIVE_DASHBOARD=true
TELEGRAM_ENABLE_SCALING_COMMANDS=true

# Discord Bot Features
DISCORD_ENABLE_SLASH_COMMANDS=true
DISCORD_ENABLE_RICH_EMBEDS=true
DISCORD_ENABLE_MODAL_INTERACTIONS=true

# Slack Bot Features
SLACK_ENABLE_SHORTCUTS=true
SLACK_ENABLE_MODALS=true
SLACK_ENABLE_INTERACTIVE_COMPONENTS=true

# Teams Bot Features
TEAMS_ENABLE_ADAPTIVE_CARDS=true
TEAMS_ENABLE_TASKS=true
TEAMS_ENABLE_BOT_FRAMEWORK=true

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Prometheus metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=200h

# Grafana dashboard
GRAFANA_ENABLED=true
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# Jaeger tracing
JAEGER_ENABLED=true
JAEGER_PORT=16686
JAEGER_COLLECTOR_PORT=14268

# Health check configuration
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3

# =============================================================================
# WEB CONFIGURATION
# =============================================================================

# Webhook URL for platform integrations
WEBHOOK_URL=https://your-domain.com/webhook/telegram
DOMAIN=your-domain.com

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================

# Agent memory limit (default: 10MB)
AGENT_MEMORY_LIMIT=10MB
PHOENIX_AGENT_MEMORY_LIMIT=10MB

# Maximum number of agents (default: 10)
MAX_AGENTS=10
PHOENIX_MAX_AGENTS=10

# Security features
SANDBOX_ENABLED=true
SECURE_EXECUTION=true
BOOT_TIMEOUT_SECONDS=1
PHOENIX_BOOT_TIMEOUT=1

# =============================================================================
# LOGGING & MONITORING
# =============================================================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info
PHOENIX_LOG_LEVEL=info

# Log format
LOG_FORMAT=json

# Monitoring configuration
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30s

# =============================================================================
# SSL CONFIGURATION (Production)
# =============================================================================

# SSL certificate paths (optional for production)
SSL_CERT_PATH=./nginx/ssl/cert.pem
SSL_KEY_PATH=./nginx/ssl/key.pem

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Security features
ENABLE_PROMPT_INJECTION_PROTECTION=true
ENABLE_ZERO_TRUST_COMM=true
ENABLE_AUDIT_LOGGING=true

# =============================================================================
# SECURITY BEST PRACTICES
# =============================================================================

# 1. Use strong, unique passwords for all secrets
# 2. Rotate secrets regularly (every 90 days)
# 3. Use environment-specific configurations
# 4. Never commit secrets to version control
# 5. Use secret management in production (HashiCorp Vault, AWS Secrets Manager)
# 6. Enable encryption at rest and in transit
# 7. Use least privilege access principles
# 8. Monitor for secret leakage and unauthorized access
